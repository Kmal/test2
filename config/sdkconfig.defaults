## Default SDK configuration for the StickS3 board-support project
##
## The StickS3 uses ESP32-S3-PICO-1-N8R8. ESP32-S3 does not support
## Bluetooth Classic / BR/EDR, so Classic Bluetooth HFP and SCO-over-HCI are
## not enabled in the StickS3 defaults. A StickS3-compatible audio transport is
## intentionally deferred and must be selected through Kconfig after a product
## transport decision is documented.

CONFIG_APP_TRANSPORT_NONE=y

## Increase the number of I2S DMA buffers for lower latency when an audio
## transport is implemented.
CONFIG_I2S_RX_DMA_BUF_COUNT=8
CONFIG_I2S_TX_DMA_BUF_COUNT=8
