{
  "soc": "ESP32-S3-PICO-1-N8R8",
  "bluetooth_classic_supported": false,
  "i2s": {
    "mclk_hz": 12288000,
    "sample_rate_hz": 16000,
    "bits": "I2S_BITS_PER_SAMPLE_16BIT",
    "pins": {
      "mclk": 18,
      "dout": 14,
      "bclk": 17,
      "lrck": 15,
      "din": 16
    },
    "bclk_hz": 512000,
    "lrck_hz": 16000,
    "profile": "capture-only no-transport default; full-duplex is opt-in"
  },
  "i2c": {
    "sda": 47,
    "scl": 48,
    "devices": {
      "es8311": 24,
      "bmi270": 104,
      "m5pm1": 110
    },
    "clk_hz": 400000
  },
  "buttons": {
    "key1": 11,
    "key2": 12,
    "forbidden": [
      35,
      37,
      39
    ]
  },
  "lcd": {
    "mosi": 39
  },
  "ir": {
    "tx": 46,
    "rx": 42,
    "rx_requires_speaker_amp_off": true
  },
  "m5pm1": {
    "l3b_enable_sequence_verified": false,
    "speaker_pulse_sequence_verified": false
  }
}
