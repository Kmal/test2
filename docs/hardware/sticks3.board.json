{
  "soc": "ESP32-S3-PICO-1-N8R8",
  "bluetooth_classic_supported": false,
  "i2s": {
    "mclk_hz": 12288000,
    "sample_rate_hz": 16000,
    "bits": "I2S_DATA_BIT_WIDTH_16BIT",
    "pins": {
      "mclk": 18,
      "dout": 14,
      "bclk": 17,
      "lrck": 15,
      "din": 16
    },
    "bclk_hz": 512000,
    "lrck_hz": 16000,
    "profile": "control firmware default; audio capture is opt-in",
    "mclk_multiple": 768
  },
  "i2c": {
    "sda": 47,
    "scl": 48,
    "devices": {
      "es8311": 24,
      "bmi270": 104,
      "m5pm1": 110
    },
    "clk_hz": 400000
  },
  "buttons": {
    "key1": 11,
    "key2": 12,
    "forbidden": [
      35,
      37,
      39
    ]
  },
  "lcd": {
    "model": "ST7789P3",
    "width": 135,
    "height": 240,
    "mosi": 39,
    "sclk": 40,
    "dc": 45,
    "cs": 41,
    "rst": 21,
    "bl": 38,
    "pixel_clock_hz": 40000000,
    "host": "SPI3_HOST",
    "x_gap": 52,
    "y_gap": 40
  },
  "ir": {
    "tx": 46,
    "rx": 42,
    "rx_requires_speaker_amp_off": true
  },
  "m5pm1": {
    "l3b_enable_sequence_verified": true,
    "speaker_pulse_sequence_verified": false
  }
}
