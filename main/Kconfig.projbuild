menu "StickS3 application transport"

choice APP_TRANSPORT
    prompt "Application audio transport"
    default APP_TRANSPORT_BLE_GATT_PCM
    help
        Select the audio transport used by the application. The StickS3 uses
        ESP32-S3, which does not support Bluetooth Classic / BR/EDR, so the
        legacy HFP transport is intentionally unavailable for this target.

config APP_TRANSPORT_NONE
    bool "No working audio transport selected"
    help
        Board bring-up only. The firmware initializes board status but does
        not claim to provide microphone transport.

config APP_TRANSPORT_BLE_GATT_PCM
    bool "Bluetooth LE GATT PCM microphone transport"
    select BT_ENABLED
    help
        Start a custom Bluetooth Low Energy GATT service and send framed
        16 kHz, 16-bit mono PCM from the ES8311 microphone as notifications.
        This is a functional Bluetooth transport for validation and custom
        host applications, not a standard Bluetooth Classic HFP or OS-native
        microphone profile.

config APP_TRANSPORT_HFP_LEGACY
    bool "Legacy Classic Bluetooth HFP transport (not StickS3/ESP32-S3)"
    depends on !IDF_TARGET_ESP32S3
    select BT_ENABLED
    select BT_HFP_CLIENT_ENABLE
    help
        Historical code path for non-ESP32-S3 targets that support Bluetooth
        Classic. It is quarantined and intentionally errors until refreshed;
        do not enable this for M5Stack StickS3.

endchoice

if APP_TRANSPORT_BLE_GATT_PCM

config APP_BLE_GATT_PCM_DEVICE_NAME
    string "BLE PCM device name"
    default "M5StickS3-Meter"

endif

endmenu


menu "StickS3 Wi-Fi and web UI"

config APP_WIFI_ENABLE
    bool "Enable Wi-Fi station/setup AP for web UI"
    default y
    help
        Start ESP-IDF Wi-Fi during boot, try saved station credentials, and
        fall back to a setup access point so the local HTTP configuration UI is
        reachable from a browser.

config APP_WIFI_AP_SSID
    string "Setup access point SSID"
    default "M5StickS3-Setup"
    depends on APP_WIFI_ENABLE

config APP_WIFI_AP_PASSWORD
    string "Setup access point password (blank for open AP)"
    default ""
    depends on APP_WIFI_ENABLE
    help
        Leave blank for an open setup AP. If set, ESP Wi-Fi requires at least
        eight characters for WPA2-PSK.

config APP_WIFI_AP_CHANNEL
    int "Setup access point channel"
    default 6
    range 1 13
    depends on APP_WIFI_ENABLE

config APP_WIFI_AP_MAX_CONNECTIONS
    int "Setup access point max clients"
    default 4
    range 1 8
    depends on APP_WIFI_ENABLE

config APP_WIFI_CONNECT_TIMEOUT_MS
    int "Station connection timeout in milliseconds"
    default 8000
    range 1000 60000
    depends on APP_WIFI_ENABLE

config APP_WIFI_MAX_SCAN_RESULTS
    int "Maximum Wi-Fi scan results shown in web UI"
    default 12
    range 1 32
    depends on APP_WIFI_ENABLE

config APP_WIFI_KEYBOARD_PROVISIONING
    bool "Prompt for Wi-Fi credentials on the LCD keyboard at boot"
    default n
    depends on APP_WIFI_ENABLE && APP_STATUS_UI_LCD
    help
        When saved station credentials are missing or fail, show a Launcher-style
        virtual keyboard on the StickS3 LCD before falling back to the setup AP.
        This is disabled by default so boot continues to the normal dashboard and
        credentials can be entered from Network > Wi-Fi Mode or the setup AP web UI.

config APP_WIFI_KEYBOARD_TIMEOUT_MS
    int "LCD keyboard provisioning timeout in milliseconds"
    default 0
    range 0 300000
    depends on APP_WIFI_KEYBOARD_PROVISIONING
    help
        Timeout for each SSID/password keyboard prompt. Set to 0 to wait
        indefinitely.

endmenu

menu "StickS3 status UI"

config APP_STATUS_UI_LCD
    bool "Render debug status on the onboard ST7789P3 LCD"
    default y
    help
        Initialize the StickS3 onboard 135x240 ST7789P3 LCD and render a
        small debug dashboard or sound-meter VU display. If LCD initialization
        fails, button polling and transport startup continue.

config APP_STATUS_UI_LCD_REFRESH_MS
    int "LCD refresh period in ms"
    default 100
    range 50 2000
    depends on APP_STATUS_UI_LCD

endmenu

menu "StickS3 sound meter"

config APP_SOUND_METER_ENABLE
    bool "Enable sound level meter application"
    depends on APP_TRANSPORT_BLE_GATT_PCM
    default y

config APP_SOUND_METER_WINDOW_MS
    int "Sound meter analysis window in milliseconds"
    default 100
    range 20 1000

config APP_SOUND_METER_TELEMETRY_HZ
    int "BLE sound telemetry rate in Hz"
    default 10
    range 1 50

config APP_SOUND_METER_DBFS_FLOOR
    int "VU meter floor in dBFS"
    default -60
    range -120 -1

config APP_SOUND_METER_LOUD_DBFS
    int "Loud threshold in dBFS"
    default -12
    range -60 0

config APP_SOUND_METER_CALIBRATION_WINDOWS
    int "Calibration analysis windows"
    default 30
    range 1 300

config APP_SOUND_METER_ENABLE_PCM_DEBUG
    bool "Allow raw PCM debug streaming mode"
    default n

endmenu
